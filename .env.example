# ─── OAuth Configuration ───
# Required for "Sign in with Google" and "Sign in with Asana" buttons.
# Without these, users can still use manual token/PAT entry.

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
# Create an OAuth 2.0 Client ID (Web application type)
# Add redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Asana OAuth (app.asana.com/0/my-apps → Create New App)
# Add redirect URI: https://your-domain.com/api/auth/asana/callback
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
